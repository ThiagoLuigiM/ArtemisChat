{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões para as janelas FAB e Chat do Artemis",
  "windows": ["fab", "chat"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:webview:allow-internal-toggle-devtools",
    "dialog:default",
    "dialog:allow-open",
    "autostart:default",
    "updater:default"
  ]
}
